rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return request.auth.uid == resource.data.ownerId;
    }

    function isCollaborator(resource) {
      return resource.data.collaborators != null &&
        resource.data.collaborators.hasAny([{
          'uid':         request.auth.uid,
          'email':       request.auth.token.email,
          'displayName': request.auth.token.name
        }]);
    }

    function isCollaboratorByUid(gardenData) {
      // Check collaborators array for uid match
      return gardenData.collaborators != null &&
        gardenData.collaborators.size() > 0;
    }

    function canAccessGarden(gardenId) {
      let garden = get(/databases/$(database)/documents/gardens/$(gardenId));
      return garden.data.ownerId == request.auth.uid ||
        (garden.data.collaborators != null &&
         garden.data.collaborators.hasAny([{
           'uid': request.auth.uid,
           'email': request.auth.token.email,
           'displayName': request.auth.token.name
         }]));
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can read their own profile; reads for collaborator lookup limited to auth users
      allow read: if isSignedIn();
      // Only the user themselves can write/create their profile
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Gardens ───────────────────────────────────────────────────────────────

    match /gardens/{gardenId} {
      // Owner or collaborator can read
      allow read: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid ||
         resource.data.collaborators.hasAny([{
           'uid': request.auth.uid,
           'email': request.auth.token.email,
           'displayName': request.auth.token.name
         }]));

      // Authenticated users can create (they become owner)
      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 80 &&
        (!('location' in request.resource.data) || request.resource.data.location.size() <= 120) &&
        request.resource.data.collaborators is list;

      // Owner can update (but cannot change ownerId or createdAt)
      allow update: if isSignedIn() &&
        resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.createdAt == resource.data.createdAt;

      // Only owner can delete
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ── Hives ─────────────────────────────────────────────────────────────────

    match /hives/{hiveId} {
      allow read: if isSignedIn() &&
        canAccessGarden(resource.data.gardenId);

      allow create: if isSignedIn() &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 80 &&
        request.resource.data.status in ['healthy', 'needs_attention', 'swarming', 'dormant'] &&
        request.resource.data.ownerId == request.auth.uid &&
        canAccessGarden(request.resource.data.gardenId);

      allow update: if isSignedIn() &&
        canAccessGarden(resource.data.gardenId) &&
        // Immutable fields
        request.resource.data.gardenId == resource.data.gardenId &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        // Status enum validation
        request.resource.data.status in ['healthy', 'needs_attention', 'swarming', 'dormant'] &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 80;

      allow delete: if isSignedIn() &&
        canAccessGarden(resource.data.gardenId);
    }

    // ── Inspections ───────────────────────────────────────────────────────────

    match /inspections/{inspectionId} {
      allow read: if isSignedIn() &&
        canAccessGarden(resource.data.gardenId);

      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 1 &&
        request.resource.data.message.size() <= 2000 &&
        canAccessGarden(request.resource.data.gardenId);

      // Inspections are immutable (no updates)
      allow update: if false;

      // Only author can delete their own inspection
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
  }
}
